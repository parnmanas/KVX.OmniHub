# API server
HOST=0.0.0.0
PORT=3000

# Database (TypeORM)
# Supported drivers: sqlite | postgres | mysql | mariadb | mssql
DB_TYPE=sqlite
DB_DATABASE=./data/omnihub.sqlite
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=omnihub
# DB_PASSWORD=changeme

# Auth
JWT_SECRET=replace-me-with-long-random-string
JWT_EXPIRES_IN=7d

# Default admin (seeded on first start if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# CORS — "*" reflects the request origin (works with credentials on LAN dev).
# In production, set to the specific origin(s) only.
CORS_ORIGIN=*
